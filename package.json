{
  "name": "servizephyr-main-app",
  "version": "0.1.8",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "desktop:dev": "concurrently -k \"cross-env NEXT_PUBLIC_IS_DESKTOP_APP=1 npm run dev\" \"wait-on http://localhost:3000 && cross-env NEXT_PUBLIC_IS_DESKTOP_APP=1 ELECTRON_DEV=1 ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "desktop:start": "cross-env NODE_ENV=production NEXT_PUBLIC_IS_DESKTOP_APP=1 electron .",
    "desktop:build": "node scripts/prepare-desktop-runtime.js && npm run build && electron-builder --win nsis --publish never",
    "desktop:build:dir": "node scripts/prepare-desktop-runtime.js && npm run build && electron-builder --win dir --publish never --config.directories.output=desktop-dist-dir --config.win.signAndEditExecutable=false",
    "desktop:refresh:unpacked": "node scripts/prepare-desktop-runtime.js && npm run build && node scripts/sync-desktop-unpacked.js",
    "desktop:build:installer": "node scripts/prepare-desktop-runtime.js && npm run build && electron-builder --win nsis --publish never -c.directories.output=desktop-dist-installer -c.win.signAndEditExecutable=false -c.nsis.include=desktop/installer.nsh -c.nsis.installerIcon=desktop/assets/icon.ico -c.nsis.uninstallerIcon=desktop/assets/icon.ico -c.nsis.installerHeaderIcon=desktop/assets/icon.ico",
    "desktop:build:portable": "node scripts/prepare-desktop-runtime.js && npm run build && electron-builder --config desktop/electron-builder-portable.json --publish never",
    "lint": "echo \"linting...\" && next lint",
    "migrate:menu-images": "node scripts/migrate-menu-images-to-storage.js",
    "backfill:business-customers": "node -r dotenv/config scripts/backfill-business-customers.js dotenv_config_path=.env.local",
    "backfill:business-customers:dry": "node -r dotenv/config -e \"process.env.DRY_RUN='true'; require('./scripts/backfill-business-customers.js')\" dotenv_config_path=.env.local",
    "cleanup:rate-limits": "node -r dotenv/config scripts/cleanup-rate-limits.js dotenv_config_path=.env.local",
    "cleanup:rate-limits:full": "node -r dotenv/config -e \"process.env.MODE='full'; require('./scripts/cleanup-rate-limits.js')\" dotenv_config_path=.env.local",
    "cleanup:idempotency-keys": "node -r dotenv/config scripts/cleanup-idempotency-keys.js dotenv_config_path=.env.local",
    "cleanup:idempotency-keys:full": "node -r dotenv/config -e \"process.env.MODE='full'; require('./scripts/cleanup-idempotency-keys.js')\" dotenv_config_path=.env.local",
    "cleanup:auth-tokens": "node -r dotenv/config scripts/cleanup-auth-tokens.js dotenv_config_path=.env.local",
    "cleanup:auth-tokens:full": "node -r dotenv/config -e \"process.env.MODE='full'; require('./scripts/cleanup-auth-tokens.js')\" dotenv_config_path=.env.local",
    "cleanup:audit-logs": "node -r dotenv/config scripts/cleanup-audit-logs.js dotenv_config_path=.env.local",
    "cleanup:audit-logs:full": "node -r dotenv/config -e \"process.env.MODE='full'; require('./scripts/cleanup-audit-logs.js')\" dotenv_config_path=.env.local",
    "inspect:security": "node -r dotenv/config scripts/inspect-security-collections.js dotenv_config_path=.env.local",
    "whatsapp:create-welcome-cta-template": "node -r dotenv/config scripts/create-whatsapp-welcome-cta-template.js dotenv_config_path=.env.local",
    "test:guest-ref": "node -r dotenv/config scripts/create-test-guest-ref.js dotenv_config_path=.env.local",
    "kiosk:launch": "powershell -ExecutionPolicy Bypass -File scripts/launch-kiosk-printing.ps1",
    "kiosk:install-startup": "powershell -ExecutionPolicy Bypass -File scripts/install-kiosk-startup.ps1",
    "kiosk:remove-startup": "powershell -ExecutionPolicy Bypass -File scripts/remove-kiosk-startup.ps1",
    "kiosk:printer:list": "powershell -ExecutionPolicy Bypass -File scripts/set-default-printer.ps1",
    "kiosk:printer:set-default": "powershell -ExecutionPolicy Bypass -File scripts/set-default-printer.ps1"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.0.0",
    "@googlemaps/react-wrapper": "^1.1.35",
    "@hello-pangea/dnd": "^16.6.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/nextjs": "^10.43.0",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.35.6",
    "@vercel/analytics": "^1.6.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/speed-insights": "^1.3.1",
    "@vis.gl/react-google-maps": "^0.10.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.8.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "0.2.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.3",
    "firebase": "^10.12.3",
    "flowbite": "^3.1.2",
    "framer-motion": "^11.3.19",
    "genkit": "^1.0.0",
    "html-to-image": "^1.11.11",
    "html5-qrcode": "^2.3.8",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^0.395.0",
    "nanoid": "^3.3.7",
    "next": "^14.2.33",
    "next-themes": "^0.3.0",
    "opus-media-recorder": "^0.8.0",
    "process": "^0.11.10",
    "qrcode.react": "^3.1.0",
    "razorpay": "^2.9.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-leaflet": "^4.2.1",
    "react-map-gl": "^7.1.7",
    "react-qr-code": "^2.0.15",
    "react-to-print": "^2.15.1",
    "react-use": "^17.5.5",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@aisuite/chub": "^0.1.1",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-popover": "^1.0.7",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@types/node": "^18.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autocannon": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.4",
    "firebase-admin": "^12.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.servizephyr.desktop",
    "productName": "ServiZephyr Desktop",
    "publish": [
      {
        "provider": "github",
        "owner": "TheServizephyr",
        "repo": "desktop-releases"
      }
    ],
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*",
      ".next/standalone/node_modules/**/*",
      ".next/static/**/*",
      "public/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/sax/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "directories": {
      "output": "desktop-dist-build",
      "buildResources": "desktop/assets"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      ".env.local",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "package.json",
      "!node_modules/**/*",
      ".next/standalone/node_modules/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/sax/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "!.next/standalone/**/*.map",
      "!.next/static/**/*.map"
    ],
    "extraResources": [
      {
        "from": "desktop/runtime/node.exe",
        "to": "node-runtime/node.exe"
      }
    ],
    "extraMetadata": {
      "main": "desktop/main.js"
    },
    "win": {
      "icon": "desktop/assets/icon.ico",
      "signAndEditExecutable": true,
      "target": [
        "nsis"
      ],
      "artifactName": "ServiZephyr-Desktop-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "ServiZephyr Desktop"
    }
  }
}
