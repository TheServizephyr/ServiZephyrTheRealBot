[debug] [2026-03-10T00:11:52.088Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/studio-6552995429-8bffe/rulesets {"name":"projects/studio-6552995429-8bffe/rulesets/696d0ad9-6d42-4771-a026-05b57320e832","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function userDocExists(uid) {\n      return exists(/databases/$(database)/documents/users/$(uid));\n    }\n\n    function currentUserDocExists() {\n      return signedIn() && userDocExists(request.auth.uid);\n    }\n\n    function currentUser() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\n    }\n\n    function isSelf(uid) {\n      return signedIn() && request.auth.uid == uid;\n    }\n\n    function isAdmin() {\n      return currentUserDocExists() &&\n        (currentUser().role == 'admin' || currentUser().isAdmin == true);\n    }\n\n    function isEmployeeStatusActive(data) {\n      return data.status == 'active' || data.isActive == true;\n    }\n\n    function canUpdateOwnUserProfile() {\n      return request.resource.data.diff(resource.data).changedKeys().hasOnly([\n        'name',\n        'phone',\n        'profilePictureUrl',\n        'notifications',\n        'lastSeen',\n        'updatedAt'\n      ]);\n    }\n\n    function canUpdateOwnDriverProfile() {\n      return request.resource.data.diff(resource.data).changedKeys().hasOnly([\n        'name',\n        'phone',\n        'profilePictureUrl',\n        'status',\n        'currentLocation',\n        'lastLocationUpdate',\n        'updatedAt'\n      ]);\n    }\n\n    function isRestaurantOwner(restaurantId) {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/restaurants/$(restaurantId)) &&\n        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;\n    }\n\n    function isShopOwner(shopId) {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/shops/$(shopId)) &&\n        get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;\n    }\n\n    function isStreetVendorOwner(vendorId) {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/street_vendors/$(vendorId)) &&\n        get(/databases/$(database)/documents/street_vendors/$(vendorId)).data.ownerId == request.auth.uid;\n    }\n\n    function isRestaurantEmployee(restaurantId) {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/restaurants/$(restaurantId)/employees/$(request.auth.uid)) &&\n        isEmployeeStatusActive(\n          get(/databases/$(database)/documents/restaurants/$(restaurantId)/employees/$(request.auth.uid)).data\n        );\n    }\n\n    function isShopEmployee(shopId) {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/shops/$(shopId)/employees/$(request.auth.uid)) &&\n        isEmployeeStatusActive(\n          get(/databases/$(database)/documents/shops/$(shopId)/employees/$(request.auth.uid)).data\n        );\n    }\n\n    function isStreetVendorEmployee(vendorId) {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/street_vendors/$(vendorId)/employees/$(request.auth.uid)) &&\n        isEmployeeStatusActive(\n          get(/databases/$(database)/documents/street_vendors/$(vendorId)/employees/$(request.auth.uid)).data\n        );\n    }\n\n    function canAccessBusiness(businessId) {\n      return isAdmin() ||\n        isRestaurantOwner(businessId) ||\n        isShopOwner(businessId) ||\n        isStreetVendorOwner(businessId) ||\n        isRestaurantEmployee(businessId) ||\n        isShopEmployee(businessId) ||\n        isStreetVendorEmployee(businessId);\n    }\n\n    function canReadOrder() {\n      return signedIn() && (\n        isAdmin() ||\n        resource.data.userId == request.auth.uid ||\n        resource.data.customerId == request.auth.uid ||\n        resource.data.deliveryBoyId == request.auth.uid ||\n        canAccessBusiness(resource.data.restaurantId)\n      );\n    }\n\n    match /users/{userId} {\n      allow read: if isSelf(userId) || isAdmin();\n      allow create: if false;\n      allow update: if isSelf(userId) && canUpdateOwnUserProfile();\n      allow delete: if false;\n    }\n\n    match /guest_profiles/{guestId} {\n      allow read, write: if false;\n    }\n\n    match /auth_tokens/{token} {\n      allow read, write: if false;\n    }\n\n    match /idempotency_keys/{keyId} {\n      allow read, write: if false;\n    }\n\n    match /split_payments/{splitId} {\n      allow get: if true;\n      allow list: if false;\n      allow create, update, delete: if false;\n    }\n\n    match /employee_invitations/{inviteCode} {\n      allow get: if true;\n      allow list: if false;\n      allow create, update, delete: if false;\n    }\n\n    match /drivers/{driverId} {\n      allow read: if isSelf(driverId) || isAdmin();\n      allow create: if false;\n      allow update: if isSelf(driverId) && canUpdateOwnDriverProfile();\n      allow delete: if false;\n\n      match /invites/{inviteId} {\n        allow read: if isSelf(driverId) || isAdmin();\n        allow delete: if isSelf(driverId) || isAdmin();\n        allow create, update: if false;\n      }\n    }\n\n    match /restaurants/{restaurantId} {\n      allow read: if signedIn();\n      allow create, update, delete: if false;\n\n      match /menu/{itemId} {\n        allow read: if signedIn();\n        allow create, update, delete: if false;\n      }\n\n      match /tables/{tableId} {\n        allow read: if canAccessBusiness(restaurantId);\n        allow create, update, delete: if false;\n      }\n\n      match /waitlist/{entryId} {\n        allow read: if canAccessBusiness(restaurantId);\n        allow create, update, delete: if false;\n      }\n\n      match /bookings/{bookingId} {\n        allow read: if canAccessBusiness(restaurantId);\n        allow create, update, delete: if false;\n      }\n\n      match /conversations/{conversationId} {\n        allow read: if canAccessBusiness(restaurantId);\n        allow create, update, delete: if false;\n\n        match /messages/{messageId} {\n          allow read: if canAccessBusiness(restaurantId);\n          allow create, update, delete: if false;\n        }\n      }\n\n      match /customers/{customerId} {\n        allow read: if isRestaurantOwner(restaurantId) || isAdmin();\n        allow create, update, delete: if false;\n      }\n\n      match /delivery_settings/{docId} {\n        allow read: if isRestaurantOwner(restaurantId) || isAdmin();\n        allow create, update, delete: if false;\n      }\n\n      match /employees/{employeeId} {\n        allow read: if isSelf(employeeId) || isRestaurantOwner(restaurantId) || isAdmin();\n        allow create, update, delete: if false;\n      }\n\n      match /dineInTabs/{tabId} {\n        allow read: if canAccessBusiness(restaurantId);\n        allow create, update, delete: if false;\n\n        match /orders/{orderId} {\n          allow read: if canAccessBusiness(restaurantId);\n          allow create, update, delete: if false;\n        }\n      }\n    }\n\n    match /shops/{shopId} {\n      allow read: if signedIn();\n      allow create, update, delete: if false;\n\n      match /menu/{itemId} {\n        allow read: if signedIn();\n        allow create, update, delete: if false;\n      }\n\n      match /tables/{tableId} {\n        allow read: if canAccessBusiness(shopId);\n        allow create, update, delete: if false;\n      }\n\n      match /waitlist/{entryId} {\n        allow read: if canAccessBusiness(shopId);\n        allow create, update, delete: if false;\n      }\n\n      match /bookings/{bookingId} {\n        allow read: if canAccessBusiness(shopId);\n        allow create, update, delete: if false;\n      }\n\n      match /conversations/{conversationId} {\n        allow read: if canAccessBusiness(shopId);\n        allow create, update, delete: if false;\n\n        match /messages/{messageId} {\n          allow read: if canAccessBusiness(shopId);\n          allow create, update, delete: if false;\n        }\n      }\n\n      match /customers/{customerId} {\n        allow read: if isShopOwner(shopId) || isAdmin();\n        allow create, update, delete: if false;\n      }\n\n      match /delivery_settings/{docId} {\n        allow read: if isShopOwner(shopId) || isAdmin();\n        allow create, update, delete: if false;\n      }\n\n      match /employees/{employeeId} {\n        allow read: if isSelf(employeeId) || isShopOwner(shopId) || isAdmin();\n        allow create, update, delete: if false;\n      }\n    }\n\n    match /street_vendors/{vendorId} {\n      allow read: if signedIn();\n      allow create, update, delete: if false;\n\n      match /menu/{itemId} {\n        allow read: if signedIn();\n        allow update, delete: if isStreetVendorOwner(vendorId) || isAdmin();\n        allow create: if false;\n      }\n\n      match /customers/{customerId} {\n        allow read: if isStreetVendorOwner(vendorId) || isAdmin();\n        allow create, update, delete: if false;\n      }\n\n      match /employees/{employeeId} {\n        allow read: if isSelf(employeeId) || isStreetVendorOwner(vendorId) || isAdmin();\n        allow create, update, delete: if false;\n      }\n\n      match /conversations/{conversationId} {\n        allow read: if canAccessBusiness(vendorId);\n        allow create, update, delete: if false;\n\n        match /messages/{messageId} {\n          allow read: if canAccessBusiness(vendorId);\n          allow create, update, delete: if false;\n        }\n      }\n    }\n\n    match /orders/{orderId} {\n      allow read: if canReadOrder();\n      allow create, update, delete: if false;\n    }\n\n    match /dine_in_tables/{tableId} {\n      allow read: if canAccessBusiness(resource.data.ownerId);\n      allow create, update, delete: if false;\n    }\n\n    match /dineInTabs/{tabId} {\n      allow read: if signedIn() && (\n        isAdmin() ||\n        resource.data.userId == request.auth.uid ||\n        resource.data.customerId == request.auth.uid ||\n        canAccessBusiness(resource.data.restaurantId)\n      );\n      allow create, update, delete: if false;\n\n      match /orders/{orderId} {\n        allow read: if signedIn() && (\n          isAdmin() ||\n          canAccessBusiness(\n            get(/databases/$(database)/documents/dineInTabs/$(tabId)).data.restaurantId\n          )\n        );\n        allow create, update, delete: if false;\n      }\n    }\n\n    match /bookings/{bookingId} {\n      allow read: if signedIn() && (\n        isAdmin() ||\n        resource.data.customerId == request.auth.uid ||\n        canAccessBusiness(resource.data.restaurantId)\n      );\n      allow create, update, delete: if false;\n    }\n\n    match /whatsapp_conversations/{conversationId} {\n      allow read: if signedIn() && (\n        isAdmin() ||\n        canAccessBusiness(resource.data.restaurantId)\n      );\n      allow create, update, delete: if false;\n\n      match /messages/{messageId} {\n        allow read: if signedIn() && (\n          isAdmin() ||\n          canAccessBusiness(\n            get(/databases/$(database)/documents/whatsapp_conversations/$(conversationId)).data.restaurantId\n          )\n        );\n        allow create, update, delete: if false;\n      }\n    }\n\n    match /service_requests/{requestId} {\n      allow read: if signedIn() && (\n        isAdmin() ||\n        canAccessBusiness(resource.data.restaurantId)\n      );\n      allow create, update, delete: if false;\n    }\n\n    match /adminMailbox/{reportId} {\n      allow read, write: if isAdmin();\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n\r\n","name":"firestore.rules"}]},"createTime":"2026-03-10T00:11:51.961183Z","metadata":{"services":["cloud.firestore"]}}
