{
  "appId": "com.servizephyr.desktop",
  "productName": "ServiZephyr Desktop",
  "asar": true,
  "asarUnpack": [
    ".next/standalone/**/*",
    ".next/static/**/*",
    "public/**/*",
    "node_modules/electron-updater/**/*",
    "node_modules/builder-util-runtime/**/*",
    "node_modules/fs-extra/**/*",
    "node_modules/graceful-fs/**/*",
    "node_modules/jsonfile/**/*",
    "node_modules/universalify/**/*",
    "node_modules/js-yaml/**/*",
    "node_modules/argparse/**/*",
    "node_modules/lazy-val/**/*",
    "node_modules/lodash.escaperegexp/**/*",
    "node_modules/lodash.isequal/**/*",
    "node_modules/semver/**/*",
    "node_modules/tiny-typed-emitter/**/*",
    "node_modules/debug/**/*",
    "node_modules/ms/**/*",
    "node_modules/sax/**/*",
    "node_modules/better-sqlite3/**/*",
    "node_modules/bindings/**/*",
    "node_modules/file-uri-to-path/**/*"
  ],
  "directories": {
    "output": "desktop-dist-portable",
    "buildResources": "desktop/assets"
  },
  "files": [
    "desktop/**/*",
    "public/**/*",
    ".env.local",
    ".next/standalone/**/*",
    ".next/static/**/*",
    "node_modules/electron-updater/**/*",
    "node_modules/builder-util-runtime/**/*",
    "node_modules/fs-extra/**/*",
    "node_modules/graceful-fs/**/*",
    "node_modules/jsonfile/**/*",
    "node_modules/universalify/**/*",
    "node_modules/js-yaml/**/*",
    "node_modules/argparse/**/*",
    "node_modules/lazy-val/**/*",
    "node_modules/lodash.escaperegexp/**/*",
    "node_modules/lodash.isequal/**/*",
    "node_modules/semver/**/*",
    "node_modules/tiny-typed-emitter/**/*",
    "node_modules/debug/**/*",
    "node_modules/ms/**/*",
    "node_modules/sax/**/*",
    "node_modules/better-sqlite3/**/*",
    "node_modules/bindings/**/*",
    "node_modules/file-uri-to-path/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "desktop/runtime/node.exe",
      "to": "node-runtime/node.exe"
    }
  ],
  "extraMetadata": {
    "main": "desktop/main.js"
  },
  "win": {
    "icon": "desktop/assets/icon.ico",
    "signAndEditExecutable": true,
    "target": [
      "portable"
    ],
    "artifactName": "ServiZephyr-Desktop-Portable-${version}.${ext}"
  }
}
